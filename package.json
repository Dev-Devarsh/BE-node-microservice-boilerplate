{
	"name": "enterprise-node-microservice",
	"version": "1.0.0",
	"description": "Enterprise-grade Node.js microservice boilerplate with DDD architecture",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsup",
		"start": "node dist/server.js",
		"lint": "eslint 'src/**/*.ts'",
		"lint:fix": "eslint 'src/**/*.ts' --fix",
		"format": "prettier --write 'src/**/*.ts'",
		"test": "jest --passWithNoTests",
		"test:watch": "jest --watch --passWithNoTests",
		"test:coverage": "jest --coverage --passWithNoTests",
		"migrate:up": "tsx src/infrastructure/migration/migrate.cli.ts up",
		"migrate:down": "tsx src/infrastructure/migration/migrate.cli.ts down",
		"migrate:status": "tsx src/infrastructure/migration/migrate.cli.ts status",
		"prepare": "husky"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"microservice",
		"typescript",
		"express",
		"mongodb",
		"ddd",
		"clean-architecture"
	],
	"license": "MIT",
	"dependencies": {
		"argon2": "^0.41.1",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"express-rate-limit": "^7.5.0",
		"helmet": "^8.0.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.9.5",
		"pino": "^9.6.0",
		"redis": "^4.7.0",
		"socket.io": "^4.8.1",
		"swagger-ui-express": "^5.0.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@socket.io/redis-adapter": "^8.3.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript-eslint/eslint-plugin": "^8.20.0",
		"@typescript-eslint/parser": "^8.20.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"lint-staged": "^15.4.3",
		"prettier": "^3.4.2",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"tsup": "^8.3.6",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3"
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix",
			"prettier --write"
		]
	}
}
