# ═══════════════════════════════════════════════════════════════════════
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in the values.
# All variables are validated at startup via Zod — missing or malformed
# values will prevent the server from booting.
# ═══════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB ─────────────────────────────────────────────
# Connection string for MongoDB. Must be a valid URI.
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/microservice_db

# ── JWT ─────────────────────────────────────────────────
# IMPORTANT: Use a strong, random 64+ character secret in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins allowed to make requests.
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ───────────────────────────────────────
# Window: 15 minutes (900000ms), Max: 100 requests per window per IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Redis ───────────────────────────────────────────────
# Optional. When set, enables:
#   - Response caching (cache-aside pattern)
#   - JWT token blacklisting (logout, password change)
#   - Socket.io Redis adapter (horizontal scaling)
#   - Distributed rate limiting (future)
# When NOT set, the app works without caching (all reads hit MongoDB).
REDIS_URL=redis://localhost:6379

# ── Logging ─────────────────────────────────────────────
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug
